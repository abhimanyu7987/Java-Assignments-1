import java.util.Scanner;

public class AbsoluteValue {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int num;

        System.out.print("Enter a number: ");
        num = sc.nextInt();

        if (num < 0) {
            num = -num;
        }

        System.out.println("Absolute value is: " + num);

        sc.close();
    }
}
